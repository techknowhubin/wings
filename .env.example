# ─────────────────────────────────────────────────────────────
# Xplorwing Wings – Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# ── Razorpay ──────────────────────────────────────────────────
# Use TEST key for development; LIVE key only in production
VITE_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# ── Sandbox / Mock Payment (development only) ─────────────────
VITE_DEV_MODE="false"   # Set "true" ONLY for local sandbox simulation

# ── Google Analytics ──────────────────────────────────────────
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ── Field-Level Encryption (AES-256-GCM) ─────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# OR use the helper: import { generateEncryptionKey } from '@/lib/crypto'
# MUST be a 32-byte value encoded as base64 (44 characters ending in =)
VITE_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY="

# ── Supabase Edge Function Secrets (set via Supabase Dashboard) ─
# These are NOT prefixed with VITE_ — they are server-side only.
# Set at: Dashboard → Project Settings → Edge Functions → Secrets
#
# RAZORPAY_KEY_SECRET="your-razorpay-secret-key"
# AISENSY_API_KEY="your-aisensy-api-key"
# AISENSY_CAMPAIGN_NAME="your-campaign-name"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# ALLOWED_ORIGIN="https://your-production-domain.com"
# ENVIRONMENT="production"   # Set to "production" in prod; omit in dev
